# fluxa.libs — Build-time library configuration
#
# Controls which libraries are compiled into the Fluxa runtime binary.
# Libs marked false are completely excluded — zero code size, zero overhead.
#
# Two levels of control:
#   fluxa.libs  — Build time: what enters the binary (this file)
#   fluxa.toml  — Run time:  what the program imports (per project)
#
# After changing this file run: make build
#
# Deps column:
#   (none)         pure C99, no external library required
#   POSIX          standard POSIX headers, available everywhere
#   pthreads       libpthread (included in glibc)
#   <lib-dev>      apt install <lib-dev> required before make build

[libs.build]
#                                                        deps
std.math      = true    # trig, sqrt, pow, log, clamp   (none)
std.csv       = true    # CSV streaming parser           (none)
std.json      = true    # JSON streaming, no DOM         (none)
std.json2     = true    # JSON full DOM, path nav, typed (none)
std.strings   = true    # split, join, trim, find, regex (none)
std.time      = true    # sleep, now_ms, elapsed         POSIX
std.fs        = true    # read, write, listdir, mkdir    POSIX
std.zlib      = true    # deflate, gzip, crc32, adler32  zlib1g-dev
std.flxthread = true    # native concurrency             pthreads
std.pid       = true    # PID controller (IoT/robotics)  (none)
std.libv      = true    # vectors, matrices, tensors     (none) [OpenBLAS optional]
std.libdsp    = true    # FFT, filters, radar DSP        (none) [FFTW3 optional]
std.crypto    = true    # BLAKE2b, XSalsa20, Ed25519     libsodium-dev
std.sqlite    = true    # embedded SQL                   libsqlite3-dev
std.serial    = true    # UART/serial port               libserialport-dev
std.i2c       = true    # I2C protocol (Linux)           (kernel header, no lib)
std.httpc     = true    # HTTP  client, plain            libcurl-dev
std.https     = true    # HTTPS client, TLS enforced     libcurl-dev
std.mqtt      = true    # MQTT client                    libmosquitto-dev
std.mcpc      = true    # MCP  client, plain HTTP        libcurl-dev
std.mcps      = true    # MCP  client, HTTPS enforced    libcurl-dev
std.websocket = true    # WebSocket client, ws:// native  (none) [libwebsockets optional: make FLUXA_WS_LWS=1]
std.http      = true    # HTTP server + client               mongoose (vendored in vendor/)
std.mcp       = true    # Fluxa as MCP server (JSON-RPC 2.0)  mongoose (vendored in vendor/)
std.graph     = true    # 2D/3D graphics, input                (none) [Raylib optional: make FLUXA_GRAPH_RAYLIB=1]
std.infer     = true    # local LLM inference, GGUF models     (none) [llama.cpp optional: make FLUXA_INFER_LLAMA=1]
