// sprint8_handover_version.flx — compatibilidade de protocolo
//
// Verifica que o runtime roda normalmente com o protocolo v1.000.
// O teste é indireto: se o runtime compilou com FLUXA_HANDOVER_VERSION=1000
// e os checksums são determinísticos, o programa deve rodar sem erro.
//
// Saída esperada:
//   v1000
//   ok

// A versão do protocolo é uma constante compilada — verificamos
// que prst + serialização funcionam como base do handover.
prst int proto_ver = 1000
print(proto_ver)
print("ok")
